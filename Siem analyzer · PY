    args = parser.parse_args()

    print("\n" + "="*60)
    print("  🛡  SOC ANALYST — SIEM LOG ANALYZER")
    print("  Threat Detection & IOC Extraction Engine")
    print("="*60 + "\n")

    engine = ThreatDetectionEngine()
    parser_obj = LogParser()

    if args.demo:
        print("[*] Running demo with sample logs...\n")
        # HTTP logs
        for line in SAMPLE_LOGS.strip().split("\n"):
            if not line.strip():
                continue
            entry = parser_obj.parse_apache(line)
            if entry:
                alerts = engine.analyze_http_log(entry)
                for a in alerts:
                    icon = {"CRITICAL":"🔴","HIGH":"🟠","MEDIUM":"🟡","LOW":"🟢"}.get(a.severity,"⚪")
                    print(f"  {icon} [{a.severity}] {a.alert_id} — {a.category}")
                    print(f"     Source: {a.source_ip} | MITRE: {a.mitre_technique or 'N/A'}")
                    print(f"     {a.description[:90]}...")
                    print()

        # Windows logs
        for line in SAMPLE_WINDOWS_LOGS.strip().split("\n"):
            if not line.strip():
                continue
            entry = parser_obj.parse_windows_event(line)
            if entry:
                alerts = engine.analyze_windows_event(entry)
                for a in alerts:
                    icon = {"CRITICAL":"🔴","HIGH":"🟠","MEDIUM":"🟡","LOW":"🟢"}.get(a.severity,"⚪")
                    print(f"  {icon} [{a.severity}] {a.alert_id} — {a.category}")
                    print()

    elif args.log_file:
        log_path = Path(args.log_file)
        if not log_path.exists():
            print(f"[!] File not found: {args.log_file}")
            sys.exit(1)
        print(f"[*] Analyzing: {args.log_file} ({args.type} format)")
        with open(log_path) as f:
            for line in f:
                if args.type == "apache":
                    entry = parser_obj.parse_apache(line)
                    if entry:
                        engine.analyze_http_log(entry)
                elif args.type == "windows":
                    entry = parser_obj.parse_windows_event(line)
                    if entry:
                        engine.analyze_windows_event(entry)
    else:
        parser.print_help()
        sys.exit(0)

    # Summary
    summary = engine.get_summary()
    print("\n" + "="*60)
    print("  📊  ANALYSIS COMPLETE")
    print("="*60)
    print(f"  Total Alerts  : {summary['total_alerts']}")
    print(f"  Critical      : {summary['severity_breakdown'].get('CRITICAL', 0)}")
    print(f"  High          : {summary['severity_breakdown'].get('HIGH', 0)}")
    print(f"  IOCs Found    : {summary['total_iocs']}")
    print(f"  Threat Actors : {', '.join(summary['unique_threat_actors']) or 'Unknown'}")
    print()

    # Reports
    if args.format in ("json", "both"):
        ReportGenerator.to_json(engine, f"{args.output}.json")
    if args.format in ("markdown", "both"):
        ReportGenerator.to_markdown(engine, f"{args.output}.md")

    print("\n[✓] Analysis complete.\n")


if __name__ == "__main__":
    main()
