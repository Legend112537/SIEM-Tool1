# ──────────────────────────────────────────
class ThreatDetectionEngine:
    """
    Core detection engine implementing:
    - Signature-based detection (regex patterns)
    - Threshold-based anomaly detection (brute force, port scans)
    - Threat intelligence correlation
    - MITRE ATT&CK mapping
    """

    def __init__(self):
        self.alerts: list[Alert] = []
        self.ioc_tracker: dict[str, IOC] = {}
        self.ip_attempt_tracker: dict[str, list] = defaultdict(list)
        self.event_counter: Counter = Counter()
        self._alert_counter = 0

    def _next_id(self) -> str:
        self._alert_counter += 1
        return f"ALERT-{datetime.now().strftime('%Y%m%d')}-{self._alert_counter:04d}"

    def _make_ioc(self, ioc_type: str, value: str, log_line: str,
                  actor: str = None, confidence: int = 50):
        now = datetime.now(timezone.utc).isoformat()
        if value in self.ioc_tracker:
            ioc = self.ioc_tracker[value]
            ioc.hit_count += 1
            ioc.last_seen = now
            ioc.source_logs.append(log_line[:120])
        else:
            self.ioc_tracker[value] = IOC(
                ioc_type=ioc_type,
                value=value,
                first_seen=now,
                last_seen=now,
                hit_count=1,
                source_logs=[log_line[:120]],
                threat_actor=actor,
                confidence=confidence,
            )

    def _check_threat_intel(self, ip: str) -> Optional[dict]:
        """Correlate IP against threat intelligence feeds."""
        return KNOWN_MALICIOUS_IPS.get(ip)

    def _check_patterns(self, text: str) -> list[tuple[str, dict]]:
        """Match text against all malicious patterns."""
        hits = []
        for pattern_name, regex in MALICIOUS_PATTERNS.items():
            if re.search(regex, text):
                hits.append((pattern_name, MITRE_MAPPING.get(pattern_name, {})))
        return hits

    def analyze_http_log(self, entry: dict) -> list[Alert]:
        """Analyze a parsed HTTP log entry for threats."""
        new_alerts = []
        ip = entry.get("ip", "")
        path = entry.get("path", "")
        ua = entry.get("user_agent", "")
        status = entry.get("status", 200)
        now = datetime.now(timezone.utc).isoformat()

        self.event_counter["http"] += 1

        # 1. Threat Intel Check
        ti_hit = self._check_threat_intel(ip)
        if ti_hit:
            alert = Alert(
                alert_id=self._next_id(),
                severity="CRITICAL",
                category="Threat Intel Hit",
                timestamp=now,
                source_ip=ip,
                destination=entry.get("path", ""),
                description=f"Known malicious IP {ip} identified as {ti_hit['actor']} "
                            f"(campaign: {ti_hit['campaign']})",
                raw_log=entry["raw"],
                threat_actor=ti_hit["actor"],
                confidence=ti_hit["confidence"],
                mitre_technique="T1566",
                mitre_tactic="Initial Access",
                tags=["threat-intel", "apt", ti_hit["actor"].lower()],
                recommended_action=f"Block IP {ip} at firewall. Investigate all sessions from this IP. "
                                   f"Escalate to Tier 2. Check for lateral movement."
            )
            new_alerts.append(alert)
            self._make_ioc("IP", ip, entry["raw"], ti_hit["actor"], ti_hit["confidence"])

        # 2. Suspicious User-Agent
        ua_lower = ua.lower()
        for bad_ua in SUSPICIOUS_USER_AGENTS:
            if bad_ua in ua_lower:
                alert = Alert(
                    alert_id=self._next_id(),
                    severity="HIGH",
                    category="Reconnaissance Tool",
                    timestamp=now,
                    source_ip=ip,
                    destination=path,
                    description=f"Automated attack tool detected: '{bad_ua}' in User-Agent from {ip}",
                    raw_log=entry["raw"],
                    confidence=85,
                    mitre_technique="T1595",
                    mitre_tactic="Reconnaissance",
                    tags=["scanning", "recon", bad_ua.split('/')[0]],
                    recommended_action=f"Rate-limit {ip}. Review full session. Consider blocking."
                )
                new_alerts.append(alert)
                self._make_ioc("IP", ip, entry["raw"], confidence=75)
                break

        # 3. Attack Pattern Detection
        full_request = f"{path} {ua}"
        pattern_hits = self._check_patterns(full_request)
        for pattern_name, mitre_info in pattern_hits:
            severity = "CRITICAL" if pattern_name in ("log4j", "shellshock", "mimikatz") else "HIGH"
            alert = Alert(
                alert_id=self._next_id(),
                severity=severity,
                category=pattern_name.replace("_", " ").title(),
                timestamp=now,
                source_ip=ip,
                destination=path,
                description=f"Attack pattern '{pattern_name}' detected in request from {ip}",
                raw_log=entry["raw"],
                confidence=90,
                mitre_technique=mitre_info.get("technique"),
                mitre_tactic=mitre_info.get("tactic"),
                tags=["attack", pattern_name],
                recommended_action=f"Block request, investigate IP {ip}, "
                                   f"check for successful exploitation ({status} response code)."
            )
            new_alerts.append(alert)

        # 4. Brute Force Detection (track 401s)
        if status in (401, 403):
            self.ip_attempt_tracker[ip].append(now)
            # Keep only last 5 minutes (simplified)
            if len(self.ip_attempt_tracker[ip]) >= 10:
                alert = Alert(
                    alert_id=self._next_id(),
                    severity="HIGH",
                    category="Brute Force",
                    timestamp=now,
                    source_ip=ip,
                    destination=path,
                    description=f"Brute force attempt: {len(self.ip_attempt_tracker[ip])} "
                                f"failed auth attempts from {ip}",
                    raw_log=entry["raw"],
                    confidence=88,
                    mitre_technique="T1110",
                    mitre_tactic="Credential Access",
                    tags=["brute-force", "credential-access"],
                    recommended_action=f"Temporarily block {ip}. Enable MFA. Review account lockout policy."
                )
                new_alerts.append(alert)
                self.ip_attempt_tracker[ip] = []  # reset

        self.alerts.extend(new_alerts)
        return new_alerts

    def analyze_windows_event(self, entry: dict) -> list[Alert]:
        """Analyze Windows Event Log entries for security events."""
        new_alerts = []
        now = datetime.now(timezone.utc).isoformat()
        eid = entry.get("event_id", 0)
        msg = entry.get("message", "")

        # Critical Windows Security Events
        CRITICAL_EVENT_IDS = {
            4624: ("Successful Logon", "LOW", "T1078", "Defense Evasion"),
            4625: ("Failed Logon", "MEDIUM", "T1110", "Credential Access"),
            4648: ("Logon with Explicit Credentials", "HIGH", "T1134", "Privilege Escalation"),
            4688: ("Process Creation", "MEDIUM", "T1059", "Execution"),
            4697: ("Service Installed", "HIGH", "T1543", "Persistence"),
            4720: ("User Account Created", "HIGH", "T1136", "Persistence"),
            4728: ("User Added to Privileged Group", "CRITICAL", "T1078.002", "Privilege Escalation"),
            4776: ("Credential Validation", "MEDIUM", "T1110", "Credential Access"),
            7045: ("New Service Installed", "HIGH", "T1543.003", "Persistence"),
        }

        if eid in CRITICAL_EVENT_IDS:
            desc, sev, tech, tactic = CRITICAL_EVENT_IDS[eid]
            # Escalate severity for suspicious process names
            pattern_hits = self._check_patterns(msg)
            if pattern_hits:
                sev = "CRITICAL"

            alert = Alert(
                alert_id=self._next_id(),
                severity=sev,
                category=f"Windows Event {eid}: {desc}",
                timestamp=now,
                source_ip=entry.get("source", ""),
                destination="Windows Host",
                description=f"Security event {eid} ({desc}): {msg[:200]}",
                raw_log=entry["raw"],
                confidence=80,
                mitre_technique=tech,
                mitre_tactic=tactic,
                tags=["windows", f"event-{eid}"],
                recommended_action=f"Investigate source of Event ID {eid}. "
                                   f"Correlate with other events from same host/time."
            )
            new_alerts.append(alert)

        self.alerts.extend(new_alerts)
        return new_alerts

    def get_summary(self) -> dict:
        """Generate executive summary of all detections."""
        severity_counts = Counter(a.severity for a in self.alerts)
        tactic_counts = Counter(a.mitre_tactic for a in self.alerts if a.mitre_tactic)
        top_ips = Counter(a.source_ip for a in self.alerts).most_common(10)

        return {
            "total_alerts": len(self.alerts),
            "severity_breakdown": dict(severity_counts),
            "top_source_ips": top_ips,
            "top_tactics": tactic_counts.most_common(5),
            "total_iocs": len(self.ioc_tracker),
            "unique_threat_actors": list({a.threat_actor for a in self.alerts if a.threat_actor}),
        }


