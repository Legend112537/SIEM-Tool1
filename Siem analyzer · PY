# REPORT GENERATOR
# ──────────────────────────────────────────
class ReportGenerator:
    """Generates structured incident reports in JSON and Markdown."""

    @staticmethod
    def to_json(engine: ThreatDetectionEngine, output_path: str = "report.json"):
        data = {
            "generated_at": datetime.now(timezone.utc).isoformat(),
            "summary": engine.get_summary(),
            "alerts": [asdict(a) for a in engine.alerts],
            "iocs": [asdict(i) for i in engine.ioc_tracker.values()],
        }
        with open(output_path, "w") as f:
            json.dump(data, f, indent=2, default=str)
        print(f"[+] JSON report saved: {output_path}")
        return data

    @staticmethod
    def to_markdown(engine: ThreatDetectionEngine, output_path: str = "report.md"):
        summary = engine.get_summary()
        lines = [
            "# 🛡 SOC Incident Analysis Report",
            f"\n**Generated:** {datetime.now(timezone.utc).strftime('%Y-%m-%d %H:%M UTC')}  ",
            f"**Analyst Tool:** SIEM Log Analyzer v1.0  \n",
            "---",
            "\n## Executive Summary\n",
            f"| Metric | Value |",
            f"|--------|-------|",
            f"| Total Alerts | **{summary['total_alerts']}** |",
            f"| Critical | 🔴 {summary['severity_breakdown'].get('CRITICAL', 0)} |",
            f"| High | 🟠 {summary['severity_breakdown'].get('HIGH', 0)} |",
            f"| Medium | 🟡 {summary['severity_breakdown'].get('MEDIUM', 0)} |",
            f"| Total IOCs | {summary['total_iocs']} |",
            f"| Threat Actors | {', '.join(summary['unique_threat_actors']) or 'N/A'} |",
            "\n---",
            "\n## Critical Alerts\n",
        ]

        for alert in [a for a in engine.alerts if a.severity == "CRITICAL"][:10]:
            lines += [
                f"### 🚨 {alert.alert_id} — {alert.category}",
                f"- **Severity:** {alert.severity}",
                f"- **Source IP:** `{alert.source_ip}`",
                f"- **Description:** {alert.description}",
                f"- **MITRE:** [{alert.mitre_technique}](https://attack.mitre.org/techniques/{alert.mitre_technique.replace('.','/')}/)" if alert.mitre_technique else "",
                f"- **Recommended Action:** {alert.recommended_action}",
                "",
            ]

        lines += ["\n---", "\n## Indicators of Compromise\n",
                  "| Type | Value | Threat Actor | Confidence | Status |",
                  "|------|-------|-------------|------------|--------|"]
        for ioc in list(engine.ioc_tracker.values())[:20]:
            lines.append(f"| {ioc.ioc_type} | `{ioc.value}` | {ioc.threat_actor or 'Unknown'} | {ioc.confidence}% | {ioc.status} |")

        lines += ["\n---", "\n## Recommendations\n",
                  "1. **Immediately block** all Critical severity source IPs at the perimeter firewall.",
                  "2. **Enable MFA** on all externally accessible services (VPN, RDP, SSH, Web Apps).",
                  "3. **Patch immediately**: Review CVEs detected (Log4Shell, Shellshock) on all systems.",
                  "4. **Hunt for compromise**: Run threat hunting queries for all CRITICAL alert IOCs.",
                  "5. **Update SIEM rules**: Add new signatures from this report to detection engine.",
                  "6. **Review EDR alerts**: Correlate endpoint telemetry with network findings.",
                  "\n---",
                  "\n*Report generated by SOC Analyst Portfolio — SIEM Log Analyzer*  ",
                  "*Tool by [Your Name] | MITRE ATT&CK® is a trademark of The MITRE Corporation*"]

        with open(output_path, "w") as f:
            f.write("\n".join(lines))
        print(f"[+] Markdown report saved: {output_path}")


